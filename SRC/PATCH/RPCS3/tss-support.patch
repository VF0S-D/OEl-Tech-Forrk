+// Load a TSS payload from the local filesystem or from RPCN as a fallback.
+// Local files are placed under <config_dir>/tss/<titleId>-<slot>.tss
+// (e.g. tss/<titleId>-0.tss).
+static u32 scenp_tss_serve_file(const shared_ptr<tus_transaction_ctx>& trans, SceNpTssSlotId slotId, vm::ptr<SceNpTssDataStatus> dataStatus, vm::ptr<void> data, u32 recvSize, vm::ptr<SceNpTssGetDataOptParam> option)
+{
+	const std::string title_id = np::communication_id_to_string(trans->communicationId);
+	const std::string file_name = fmt::format("%s-%d.tss", title_id, slotId);
+	const std::string file_path = fs::get_config_dir() + "tss/" + file_name;
+
+	std::vector<u8> buf;
+
+	fs::file f(file_path, fs::read);
+	if (f)
+	{
+		sceNpTus.notice("[TSS] Reading local file %s", file_path);
+		buf.resize(f.size());
+		if (!buf.empty() && f.read(buf.data(), buf.size()) != buf.size())
+		{
+			sceNpTus.error("[TSS] Read error for %s", file_path);
+			scenp_tss_no_file(trans, dataStatus);
+			return 0;
+		}
+	}
+	else
+	{
+		sceNpTus.notice("[TSS] Local file not found (%s), fetching from RPCN", file_path);
+		buf = scenp_tss_fetch_from_rpcn(title_id, file_name);
+		if (buf.empty())
+		{
+			sceNpTus.warning("[TSS] %s not available locally or from RPCN", file_name);
+			scenp_tss_no_file(trans, dataStatus);
+			return 0;
+		}
+	}
+
+	const u64 file_size = buf.size();
+	u64 read_offset = 0;
+	u64 read_limit = file_size;
+
+	if (option)
+	{
+		if (option->offset)
+		{
+			read_offset = std::min<u64>(*option->offset, file_size);
+		}
+
+		if (option->lastByte)
+		{
+			const u64 requested_end = *option->lastByte == std::numeric_limits<u64>::max() ? file_size : std::min<u64>(*option->lastByte + 1, file_size);
+			read_limit = std::max(read_offset, requested_end);
+		}
+
+		if (option->ifParam)
+		{
+			sceNpTus.notice("[TSS] Ignoring ifParam for %s (type=%d)", file_name, option->ifParam->ifType);
+		}
+	}
+
+	const u64 range_size = read_limit - read_offset;
+
+	if (read_offset != 0 || read_limit != file_size)
+	{
+		sceNpTus.warning("[TSS] Partial range request for %s: offset=%llu lastByte=%llu fileSize=%llu rangeBytes=%llu",
+			file_name, read_offset, read_limit - 1, file_size, range_size);
+	}
+
+	sceNpTus.notice("[TSS] Serving %s (offset=%llu, bytes=%llu)", file_name, read_offset, range_size);
+
+	// Initialized once at first TSS serve; used as a stable lastModified timestamp for the session.
+	static const u64 s_session_start_tick = static_cast<u64>(
+		std::chrono::duration_cast<std::chrono::microseconds>(
+			std::chrono::system_clock::now().time_since_epoch()).count());
+
+	auto* status = dataStatus.get_ptr();
+	std::memset(status, 0, sizeof(SceNpTssDataStatus));
+	status->lastModified.tick = s_session_start_tick;
+	status->contentLength = static_cast<u32>(file_size);
+	status->statusCodeType = (read_offset != 0 || read_limit != file_size) ? SCE_NP_TSS_STATUS_TYPE_PARTIAL : SCE_NP_TSS_STATUS_TYPE_OK;
+
+	u32 copy_bytes = 0;
+
+	if (data && recvSize > 0)
+	{
+		copy_bytes = static_cast<u32>(std::min<u64>(range_size, recvSize));
+
+		if (copy_bytes != 0)
+		{
+			std::memcpy(data.get_ptr(), buf.data() + read_offset, copy_bytes);
+		}
+
+		if (copy_bytes < range_size)
+		{
+			sceNpTus.warning("[TSS] Buffer too small for %s: recvSize=%u rangeBytes=%llu clipped=%llu bytes lost",
+				file_name, recvSize, range_size, range_size - copy_bytes);
+			status->statusCodeType = SCE_NP_TSS_STATUS_TYPE_PARTIAL;
+		}
+	}
+
+	trans->result = not_an_error(copy_bytes);
+	return copy_bytes;
+}
