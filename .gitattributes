# Normalize line endings
* text=auto

# Source / config text files
*.py          text eol=lf
*.bat         text eol=crlf
*.ps1         text eol=crlf
*.iss         text eol=crlf
*.yml         text eol=lf
*.yaml        text eol=lf
*.md          text eol=lf
*.txt         text eol=lf
*.cfg         text eol=lf
*.toml        text eol=lf
*.json        text eol=lf
*.qss         text eol=lf
*.patch       text eol=lf
*.qrc         text eol=lf
*.ui          text eol=lf
*.h           text eol=lf
*.hpp         text eol=lf
*.cpp         text eol=lf
*.c           text eol=lf
*.rs          text eol=lf

# Binary assets -- prevent line-ending mangling
*.dat         binary
*.png         binary
*.jpg         binary
*.jpeg        binary
