+// If a restore sentinel (<config_dir>/tus/<commId>/<npId>/<slot_20d>.tdt.restore) exists,
+// serve its contents directly and delete the sentinel (one-shot).
+// Returns nullopt when no sentinel is present (fall through to RPCN).
+// Returns SCE_NP_COMMUNITY_SERVER_ERROR_USER_STORAGE_DATA_NOT_FOUND when the sentinel is
+// empty (zero-byte file — "create new game" path, mirrors RPCN's own no-data response).
+// Returns not_an_error(bytes_copied) when the sentinel contains backup data.
+static std::optional<error_code> scenp_tus_serve_restore(const shared_ptr<tus_transaction_ctx>& trans,
+	const SceNpOnlineId& targetNpId, SceNpTusSlotId slotId,
+	vm::ptr<SceNpTusDataStatus> dataStatus, vm::ptr<void> data, u32 recvSize)
+{
+	const std::string comm_id     = np::communication_id_to_string(trans->communicationId);
+	const std::string np_id       = std::string(targetNpId.data);
+	const std::string restore_path = fmt::format("%stus/%s/%s/%020d.tdt.restore",
+		fs::get_config_dir(), comm_id, np_id, slotId);
+
+	fs::file f(restore_path, fs::read);
+	if (!f)
+		return std::nullopt;
+
+	sceNpTus.notice("[TUS] Restore sentinel found for slot %d: %s", slotId, restore_path);
+
+	std::vector<u8> buf(f.size());
+	if (!buf.empty() && f.read(buf.data(), buf.size()) != buf.size())
+	{
+		sceNpTus.error("[TUS] Read error for restore file: %s", restore_path);
+		return std::nullopt;
+	}
+	f.close();
+
+	// Remove sentinel so the next GetData goes to RPCN as normal.
+	fs::remove_file(restore_path);
+
+	// Empty sentinel = "no data" — mirrors the real RPCN no-data response so the
+	// game treats this exactly like a fresh account with no cloud save.
+	if (buf.empty())
+	{
+		sceNpTus.notice("[TUS] Empty sentinel for slot %d — reporting USER_STORAGE_DATA_NOT_FOUND (new game)", slotId);
+		return {SCE_NP_COMMUNITY_SERVER_ERROR_USER_STORAGE_DATA_NOT_FOUND};
+	}
+
+	sceNpTus.notice("[TUS] Restore complete for slot %d, sentinel removed", slotId);
+
+	const u32 file_size  = static_cast<u32>(buf.size());
+	const u32 copy_bytes = std::min(file_size, recvSize);
+
+	if (copy_bytes > 0)
+		std::memcpy(data.get_ptr(), buf.data(), copy_bytes);
+
+	auto* status = dataStatus.get_ptr();
+	std::memset(status, 0, sizeof(SceNpTusDataStatus));
+	np::string_to_npid(np_id, status->ownerId);
+	status->hasData              = 1;
+	status->lastChangedDate.tick = 0;
+	status->lastChangedAuthorId  = status->ownerId;
+	status->data                 = data;
+	status->dataSize             = file_size;
+
+	return not_an_error(copy_bytes);
+}
